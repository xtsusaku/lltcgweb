    {
      "id": "intro_welcome",
      "dialogue": "Hi! I'm **Shibuya Kanon**. Welcome to the **Love Live! Official Card Game** tutorial!",
      "highlights": [],
      "actions": []
    },
    {
      "id": "intro_what",
      "dialogue": "This is a **two-player** card game about **school idols**! You'll recruit **Members** onto your Stage, manage **Energy**, and perform **Lives** to outshine your opponent.",
      "highlights": [],
      "actions": []
    },
    {
      "id": "intro_goal",
      "dialogue": "**Win condition:** Successfully perform **3 Lives** before your opponent. When your **Live** is a success, that Live moves to the **Success Live card storage** — first to three wins the match!",
      "highlights": [
        {
          "target": "my-pips",
          "shape": "rounded",
          "padding": 14
        },
        {
          "target": "opp-pips",
          "shape": "rounded",
          "padding": 14
        }
      ],
      "actions": []
    },
    {
      "id": "intro_decks",
      "dialogue": "This game uses three types of cards. **Member** cards, **Live** cards and **Energy** cards. Each player has a **Main Deck** of **60** cards (**48 Member** cards and **12 Live** cards) and an **Energy Deck** of **12 Energy** cards.",
      "highlights": [],
      "actions": []
    },
    {
      "id": "intro_card_member",
      "dialogue": "**Member cards** are the idols that will perform on Stage. Pay **Energy** equal to their cost to play them from your hand. Each Member has a certain amount of colored **Hearts** (upright) that are used when performing lives. There are also **Blades** (the round penlight icons) and **Blade hearts** (The sideways hearts), but we'll focus on the upright heart for now. Shiki here has **1 purple heart**.",
      "highlights": [
        {
          "target": "hand-row",
          "shape": "rounded",
          "padding": 8
        },
        {
          "target": "card-hover-panel",
          "shape": "rounded",
          "padding": 8
        }
      ],
      "actions": [],
      "select_hand": "PL!SP-sd1-019-SD"
    },
    {
      "id": "intro_card_live",
      "dialogue": "**Live cards** are the songs you perform. You can play up to 3 at a time. Lives are cleared using the **Member** cards you've placed on your stage - we'll touch on this more later.",
      "highlights": [
